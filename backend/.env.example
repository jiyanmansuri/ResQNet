# Copy this to .env for local dev (do NOT commit .env to git)
# Set these same variables in Railway dashboard for production

# HiveMQ Cloud MQTT broker
# Get these from https://console.hivemq.cloud/
MQTT_HOST=your-cluster.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=your_hivemq_username
MQTT_PASSWORD=your_hivemq_password
MQTT_TLS=true

# Server port (Railway sets this automatically — don't change for production)
PORT=5000
